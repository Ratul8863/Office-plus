# Discord bot configuration
# Create a bot at https://discord.com/developers/applications
# and paste its token below. NEVER commit your real token.
DISCORD_TOKEN=

# OfficePulse backend base URL. The bot calls it for all live data.
BACKEND_API_URL=http://localhost:5000

# Optional: restrict the bot to a specific channel ID (leave blank to accept any channel)
DISCORD_CHANNEL_ID=

# Optional: enable LLM humanizer layer (keep disabled for now; templates are used).
LLM_ENABLED=false

# Optional LLM credentials (only used if LLM_ENABLED=true)
GROQ_API_KEY=
OPENAI_API_KEY=
