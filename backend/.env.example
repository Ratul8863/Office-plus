PORT=5000
NODE_ENV=development
# Comma-separated browser origins allowed to call the backend.
CLIENT_URL=http://localhost:8080,https://eco-electricity-zeta.vercel.app
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=1522604103245496400&permissions=115712&integration_type=0&scope=bot+applications.commands
DISCORD_COMMAND_PREFIX=!
DISCORD_ALERT_NOTIFICATIONS_ENABLED=true

# Work Room 1 and Work Room 2 are flagged as simulator-source rooms.
# Manual device control via the API works regardless of these flags.
ENABLE_SIMULATOR=true
# When false, the backend does NOT randomly toggle simulator devices —
# only manual API calls change state. Set true to re-enable auto ticking.
ENABLE_RANDOM_SIMULATOR=false
SIMULATOR_INTERVAL_MS=8000

HIGH_USAGE_THRESHOLD_WATT=300

# Optional: MongoDB persistence. Leave MONGODB_URI blank to run the backend
# in memory-only mode. When set, device state, device events, alerts, and
# usage snapshots are persisted across restarts.
MONGODB_URI=
MONGODB_DB_NAME=officepulse

# Local Node/Wokwi can use tcp://1883. Hosted deployments like Render may need
# HiveMQ's websocket endpoint instead: wss://broker.hivemq.com:8884/mqtt
MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=officepulse-backend-local
MQTT_TOPIC=office/wokwi/work1/telemetry
MQTT_HARDWARE_TOPIC_PREFIX=smartoffice/drawing
# Seconds without telemetry before the backend marks Wokwi as offline and
# triggers the DEVICE_OFFLINE critical alert. Also drives the sidebar
# 'Hardware Bridge (Drawing)' connection indicator via Socket.IO connection:status.
WOKWI_OFFLINE_TIMEOUT_SECONDS=60
